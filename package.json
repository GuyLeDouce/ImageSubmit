{
  "name": "squig-survival-image-submission-app",
  "version": "1.0.0",
  "description": "Discord-authenticated moderation app for Squig Survival image submissions.",
  "main": "src/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "npm run db:migrate && node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "npm run test:unit",
    "test:unit": "node --test tests/domain.test.js tests/mint-check.test.js",
    "test:contract": "node --test tests/contract-static.test.js",
    "test:migrations": "node --test tests/migrations.test.js",
    "test:integration": "node --test tests/integration-db.test.js tests/startup.test.js",
    "test:security": "node --test tests/security.test.js tests/health.test.js",
    "test:all": "npm run test:unit && npm run test:contract && npm run test:migrations && npm run test:integration && npm run test:security",
    "check:mint": "node scripts/check-mint-copy.js",
    "db:preflight": "node scripts/db-preflight.js",
    "db:migrate": "node scripts/migrate.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.918.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.16.3"
  }
}
