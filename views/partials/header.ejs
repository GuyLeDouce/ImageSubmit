<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="<%= csrfToken %>" />
    <title><%= title %> | Squig Survival</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="<%= currentPath === '/' ? 'home-page' : '' %>">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="page-shell">
      <header class="topbar">
        <div class="topbar-brand">
          <a
            class="logo-button"
            href="/"
            aria-label="Squigs Reloaded Creator Portal home"
          >
            <img src="/squigs-logo-full.png" alt="Squigs logo" />
          </a>
          <div class="brand-copy">
            <a class="brand-kicker" href="/">Squigs Reloaded</a>
            <a class="brand" href="/">Creator Portal</a>
          </div>
        </div>

        <nav class="nav">
          <div class="nav-links">
            <a class="buy-squigs-link" href="<%= links.openSea %>" target="_blank" rel="noreferrer">Buy Squigs</a>
            <a href="<%= links.squigsHome %>" target="_blank" rel="noreferrer">Explore Reloaded</a>
            <% if (user) { %>
              <a href="/profile">Profile</a>
              <a href="/submit">Submit</a>
              <% if (isAdmin) { %>
                <a href="/admin">Admin</a>
              <% } %>
              <form action="/logout" method="post" class="inline-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="link-button">Log out</button>
              </form>
            <% } else { %>
              <a href="/auth/discord">Login with Discord</a>
            <% } %>
          </div>

          <div class="social-links" aria-label="Squigs links">
            <a
              class="social-button"
              href="<%= links.discord %>"
              target="_blank"
              rel="noreferrer"
              aria-label="Open Squigs Discord"
            >
              <img src="https://i.imgur.com/1gXY4wm.png" alt="" aria-hidden="true" />
            </a>
            <a
              class="social-button"
              href="<%= links.x %>"
              target="_blank"
              rel="noreferrer"
              aria-label="Open Squigs on X"
            >
              <img src="https://i.imgur.com/miO8HjA.png" alt="" aria-hidden="true" />
            </a>
          </div>
        </nav>
      </header>

      <% if (flash) { %>
        <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
      <% } %>

      <main class="main-card" id="main-content">
