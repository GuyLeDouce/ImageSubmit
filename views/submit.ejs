<%- include("partials/header") %>

<%
  const eraLabel = eras[0]?.label || "The Rise of Ugly City";
  const selectedMilestoneKey = selectedMilestone?.key || "";
  const conceptByMilestone = milestoneConcepts || {};
  const defaultMilestoneConcept = "Choose a milestone to see what kind of Ugly City image fits that chapter.";
  const selectedMilestoneConcept = conceptByMilestone[selectedMilestoneKey] || defaultMilestoneConcept;
  const submissionGroups = [
    { key: "pending", title: "Awaiting Approval", emptyText: "No images waiting for review yet." },
    { key: "approved", title: "Approved", emptyText: "No approved images yet." },
    { key: "declined", title: "Declined", emptyText: "No declined images." },
  ].map((group) => ({
    ...group,
    items: (submissions || []).filter((submission) => submission.status === group.key),
  }));
%>

<section class="stack-gap submit-page">
  <header class="dashboard-hero">
    <div>
      <p class="eyebrow">Creator Dashboard</p>
      <h1>Submit your image</h1>
      <p class="lead">Images go to admin review first. Approved images become eligible for the Ugly City image pool and earn 100 $CHARM.</p>
    </div>
    <div class="user-badge">
      <span>Discord account</span>
      <strong><%= user.username %></strong>
      <small><%= user.id %></small>
    </div>
  </header>

  <% if (submitted) { %>
    <div class="success-box">
      Your Ugly City image has been submitted for review. If approved, it will enter the Ugly City image pool and earn 100 $CHARM.
    </div>
  <% } %>

  <div class="submit-layout submit-layout--single">
    <form action="/submit" method="post" enctype="multipart/form-data" class="stack-gap panel form-panel">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="era_key" value="ugly_city" />

      <div class="form-panel__header">
        <p class="eyebrow">Upload Station</p>
        <h2>The Rise of Ugly City</h2>
      </div>

      <label class="field">
        <span>Selected milestone</span>
        <select name="milestone_key" required data-milestone-select aria-describedby="milestone-concept-note">
          <option value="">Choose an Ugly City milestone</option>
          <% milestones.forEach((milestone) => { %>
            <option
              value="<%= milestone.key %>"
              data-concept="<%= conceptByMilestone[milestone.key] || defaultMilestoneConcept %>"
              <%= milestone.key === selectedMilestoneKey ? "selected" : "" %>
            >
              <%= milestone.number %>. <%= milestone.district %>
            </option>
          <% }) %>
        </select>
        <small
          class="field-note milestone-concept-note"
          id="milestone-concept-note"
          data-default-text="<%= defaultMilestoneConcept %>"
        ><%= selectedMilestoneConcept %></small>
      </label>

      <label class="field file-field">
        <span>Image uploads</span>
        <input type="file" name="images" accept="image/png,image/jpeg,image/webp,image/gif" multiple required />
        <small class="field-note">You can submit up to 10 images at once. Each image will be reviewed separately.</small>
      </label>

      <label class="checkbox-field">
        <input type="checkbox" name="contains_squig_confirmed" required />
        <span>I confirm this image includes at least one Squig.</span>
      </label>

      <label class="field">
        <span>Other NFTs / collections included (optional)</span>
        <input
          type="text"
          name="other_collections_text"
          maxlength="500"
          placeholder="Collection names, characters, memes, or source notes"
        />
      </label>

      <label class="field">
        <span>Prompt used (optional)</span>
        <textarea
          name="prompt_text"
          rows="5"
          maxlength="4000"
          placeholder="Paste the prompt you used to create this image"
        ></textarea>
      </label>

      <p class="reward-note">Approved images earn 100 $CHARM.</p>
      <button type="submit" class="button">Submit to Ugly City</button>
    </form>
  </div>

  <section class="stack-gap submission-history">
    <div class="submission-history__header">
      <p class="eyebrow">Your submissions</p>
      <h2>Images linked to your Discord account</h2>
      <p class="muted">These are only the images submitted by <strong><%= user.username %></strong>.</p>
    </div>

    <% submissionGroups.forEach((group) => { %>
      <div class="panel submission-group">
        <div class="submission-group__heading">
          <h3><%= group.title %></h3>
          <span class="submission-count"><%= group.items.length %></span>
        </div>

        <% if (!group.items.length) { %>
          <p class="muted empty-state"><%= group.emptyText %></p>
        <% } else { %>
          <div class="submission-grid">
            <% group.items.forEach((submission) => { %>
              <article class="submission-tile submission-tile--<%= submission.status %>">
                <a href="<%= submission.image_url %>" target="_blank" rel="noreferrer" class="submission-tile__media">
                  <img src="<%= submission.image_url %>" alt="Submitted image <%= submission.id %>" loading="lazy" />
                </a>
                <div class="submission-tile__body">
                  <div class="submission-tile__topline">
                    <span class="submission-status submission-status--<%= submission.status %>">
                      <%= group.title %>
                    </span>
                    <span class="submission-tile__date">
                      <%= new Date(submission.submitted_at).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %>
                    </span>
                  </div>

                  <dl class="submission-tile__meta">
                    <div>
                      <dt>Era</dt>
                      <dd><%= eraLabel %></dd>
                    </div>
                    <div>
                      <dt>Milestone</dt>
                      <dd><%= submission.milestone_label || submission.milestone_key || "Not set" %></dd>
                    </div>
                    <div>
                      <dt>Reward</dt>
                      <dd><%= submission.reward_points || 100 %> $CHARM</dd>
                    </div>
                    <% if (submission.other_collections_text || submission.nft_used_text) { %>
                      <div>
                        <dt>Other collections</dt>
                        <dd><%= submission.other_collections_text || submission.nft_used_text %></dd>
                      </div>
                    <% } %>
                    <% if (submission.status !== "pending") { %>
                      <div>
                        <dt>Reviewed</dt>
                        <dd>
                          <%= submission.reviewed_at ? new Date(submission.reviewed_at).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) : "Not available" %>
                        </dd>
                      </div>
                    <% } %>
                    <% if (submission.status === "declined" && submission.decline_reason) { %>
                      <div class="decline-reason">
                        <dt>Reason</dt>
                        <dd><%= submission.decline_reason %></dd>
                      </div>
                    <% } %>
                  </dl>

                  <% if (submission.prompt_text) { %>
                    <p class="submission-tile__prompt"><%= submission.prompt_text %></p>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% }) %>
  </section>
</section>

<script nonce="<%= cspNonce %>">
  (() => {
    const select = document.querySelector("[data-milestone-select]");
    const note = document.getElementById("milestone-concept-note");
    if (!select || !note) return;

    const updateConcept = () => {
      const option = select.options[select.selectedIndex];
      note.textContent = option?.dataset.concept || note.dataset.defaultText;
    };

    select.addEventListener("change", updateConcept);
    updateConcept();
  })();
</script>

<%- include("partials/footer") %>
