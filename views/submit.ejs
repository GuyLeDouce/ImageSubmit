<%- include("partials/header") %>

<section class="stack-gap narrow form-shell">
  <p class="eyebrow">Submission form</p>
  <h1>Submit your image</h1>
  <p class="muted">Logged in as <strong><%= user.username %></strong> (<%= user.id %>)</p>

  <% if (submitted) { %>
    <div class="success-box">
      Your image has been submitted for review. Watch for approval in <a href="https://discord.gg/UJgqevGaGV" target="_blank" rel="noreferrer">squigs.io/discord</a>.
    </div>
  <% } %>

  <form action="/submit" method="post" enctype="multipart/form-data" class="stack-gap panel form-panel">
    <label class="field">
      <span>Era</span>
      <select name="era_key" required>
        <option value="">Choose an era</option>
        <% eras.forEach((era) => { %>
          <option value="<%= era.key %>"><%= era.label %></option>
        <% }) %>
      </select>
    </label>

    <label class="field">
      <span>Image upload</span>
      <input type="file" name="image" accept="image/png,image/jpeg,image/webp,image/gif" required />
    </label>

    <label class="field">
      <span>NFT used</span>
      <select name="nft_used_type" data-nft-type-select required>
        <option value="squigs" selected>Squigs</option>
        <option value="other">Other</option>
      </select>
    </label>

    <label class="field is-hidden" data-nft-other-field>
      <span>Which NFT?</span>
      <input
        type="text"
        name="nft_used_text"
        maxlength="200"
        placeholder="Add the NFT used"
        data-nft-other-input
      />
    </label>

    <label class="field">
      <span>Prompt used (optional)</span>
      <textarea
        name="prompt_text"
        rows="5"
        maxlength="4000"
        placeholder="Paste the prompt you used to create this image"
      ></textarea>
    </label>

    <button type="submit" class="button">Submit</button>
  </form>
</section>

<script>
  (() => {
    const typeSelect = document.querySelector("[data-nft-type-select]");
    const otherField = document.querySelector("[data-nft-other-field]");
    const otherInput = document.querySelector("[data-nft-other-input]");
    if (!typeSelect || !otherField || !otherInput) return;

    const syncOtherField = () => {
      const isOther = typeSelect.value === "other";
      otherField.classList.toggle("is-hidden", !isOther);
      otherInput.required = isOther;
      if (!isOther) otherInput.value = "";
    };

    typeSelect.addEventListener("change", syncOtherField);
    syncOtherField();
  })();
</script>

<%- include("partials/footer") %>
