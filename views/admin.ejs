<%- include("partials/header") %>

<section class="stack-gap">
  <div>
    <p class="eyebrow">Admin review</p>
    <h1>Pending submissions</h1>
    <p class="muted">Only allowlisted Discord admins can access this page.</p>
  </div>

  <% if (!submissions.length) { %>
    <div class="panel">No pending submissions.</div>
  <% } %>

  <% submissions.forEach((submission) => { %>
    <article class="submission-card">
      <div class="submission-media">
        <a href="<%= submission.image_url %>" target="_blank" rel="noreferrer">
          <img src="<%= submission.image_url %>" alt="Submission <%= submission.id %> preview" />
        </a>
      </div>
      <div class="submission-body">
        <h2>Submission #<%= submission.id %></h2>
        <dl class="meta-grid">
          <div><dt>Discord username</dt><dd><%= submission.discord_username %></dd></div>
          <div><dt>Discord user ID</dt><dd><%= submission.discord_user_id %></dd></div>
          <div><dt>Display name</dt><dd><%= submission.discord_display_name || "Not set" %></dd></div>
          <div><dt>Era</dt><dd><%= submission.era_key %></dd></div>
          <div><dt>NFT Used</dt><dd><%= submission.nft_used_type === "other" ? (submission.nft_used_text || "Other") : "Squigs" %></dd></div>
          <div><dt>Prompt</dt><dd><%= submission.prompt_text || "Not provided" %></dd></div>
          <div><dt>Submitted</dt><dd><%= new Date(submission.submitted_at).toLocaleString() %></dd></div>
          <div><dt>Image URL</dt><dd><a href="<%= submission.image_url %>" target="_blank" rel="noreferrer">Open image</a></dd></div>
        </dl>

        <div class="actions review-actions">
          <form action="/admin/submissions/<%= submission.id %>/approve" method="post" class="approve-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label class="field">
              <span>Override Discord user ID</span>
              <input
                type="text"
                name="override_discord_user_id"
                inputmode="numeric"
                placeholder="<%= submission.discord_user_id %>"
              />
            </label>
            <label class="field">
              <span>Override username</span>
              <input
                type="text"
                name="override_discord_username"
                placeholder="<%= submission.discord_username %>"
              />
            </label>
            <label class="field">
              <span>Override display name</span>
              <input
                type="text"
                name="override_discord_display_name"
                placeholder="<%= submission.discord_display_name || 'Not set' %>"
              />
            </label>
            <label class="field">
              <span>Era</span>
              <select name="override_era_key" required>
                <% eras.forEach((era) => { %>
                  <option value="<%= era.key %>" <%= era.key === submission.era_key ? "selected" : "" %>><%= era.label %></option>
                <% }) %>
              </select>
            </label>
            <label class="field">
              <span>NFT used</span>
              <select
                name="override_nft_used_type"
                required
                data-nft-type-select
              >
                <option value="squigs" <%= submission.nft_used_type === "squigs" ? "selected" : "" %>>Squigs Reloaded</option>
                <option value="other" <%= submission.nft_used_type === "other" ? "selected" : "" %>>Other</option>
              </select>
            </label>
            <label class="field <%= submission.nft_used_type === 'other' ? '' : 'is-hidden' %>" data-nft-other-field>
              <span>Which NFT?</span>
              <input
                type="text"
                name="override_nft_used_text"
                value="<%= submission.nft_used_text || '' %>"
                maxlength="200"
                placeholder="Add the NFT used"
                data-nft-other-input
              />
            </label>
            <label class="field small-field">
              <span>Reward points</span>
              <input
                type="number"
                min="0"
                max="100000"
                name="reward_points"
                value="<%= submission.reward_points %>"
                required
                data-reward-input
              />
            </label>
            <button type="submit" class="button">Accept</button>
          </form>

          <form action="/admin/submissions/<%= submission.id %>/decline" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label class="field">
              <span>Decline reason</span>
              <textarea name="reason" rows="3" maxlength="500" required placeholder="Explain what needs to change"></textarea>
            </label>
            <button type="submit" class="button danger">Decline</button>
          </form>
        </div>
      </div>
    </article>
  <% }) %>
</section>

<section class="stack-gap">
  <div>
    <p class="eyebrow">Approved library</p>
    <h1>Approved images</h1>
    <p class="muted">Approved entries remain visible here so admins can review and edit them later.</p>
  </div>

  <% if (!approvedSubmissions.length) { %>
    <div class="panel">No approved images yet.</div>
  <% } %>

  <% approvedSubmissions.forEach((submission) => { %>
    <article class="submission-card">
      <div class="submission-media">
        <a href="<%= submission.image_url %>" target="_blank" rel="noreferrer">
          <img src="<%= submission.image_url %>" alt="Approved submission <%= submission.id %> preview" />
        </a>
      </div>
      <div class="submission-body">
        <h2>Approved #<%= submission.id %></h2>
        <dl class="meta-grid">
          <div><dt>Discord username</dt><dd><%= submission.discord_username %></dd></div>
          <div><dt>Discord user ID</dt><dd><%= submission.discord_user_id %></dd></div>
          <div><dt>Display name</dt><dd><%= submission.discord_display_name || "Not set" %></dd></div>
          <div><dt>Era</dt><dd><%= submission.era_key %></dd></div>
          <div><dt>NFT Used</dt><dd><%= submission.nft_used_type === "other" ? (submission.nft_used_text || "Other") : "Squigs" %></dd></div>
          <div><dt>Prompt</dt><dd><%= submission.prompt_text || "Not provided" %></dd></div>
          <div><dt>Reward points</dt><dd><%= submission.reward_points %></dd></div>
          <div><dt>Approved</dt><dd><%= submission.reviewed_at ? new Date(submission.reviewed_at).toLocaleString() : "Unknown" %></dd></div>
          <div><dt>Approved by</dt><dd><%= submission.reviewed_by || "Unknown" %></dd></div>
          <div><dt>Image URL</dt><dd><a href="<%= submission.image_url %>" target="_blank" rel="noreferrer">Open image</a></dd></div>
        </dl>

        <div class="actions review-actions">
          <form action="/admin/submissions/<%= submission.id %>/update-approved" method="post" class="approve-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label class="field">
              <span>Discord user ID</span>
              <input
                type="text"
                name="override_discord_user_id"
                inputmode="numeric"
                value="<%= submission.discord_user_id %>"
              />
            </label>
            <label class="field">
              <span>Username</span>
              <input
                type="text"
                name="override_discord_username"
                value="<%= submission.discord_username %>"
              />
            </label>
            <label class="field">
              <span>Display name</span>
              <input
                type="text"
                name="override_discord_display_name"
                value="<%= submission.discord_display_name || '' %>"
                placeholder="Not set"
              />
            </label>
            <label class="field">
              <span>Era</span>
              <select name="override_era_key" required>
                <% eras.forEach((era) => { %>
                  <option value="<%= era.key %>" <%= era.key === submission.era_key ? "selected" : "" %>><%= era.label %></option>
                <% }) %>
              </select>
            </label>
            <label class="field">
              <span>NFT used</span>
              <select
                name="override_nft_used_type"
                required
                data-nft-type-select
              >
                <option value="squigs" <%= submission.nft_used_type === "squigs" ? "selected" : "" %>>Squigs Reloaded</option>
                <option value="other" <%= submission.nft_used_type === "other" ? "selected" : "" %>>Other</option>
              </select>
            </label>
            <label class="field <%= submission.nft_used_type === 'other' ? '' : 'is-hidden' %>" data-nft-other-field>
              <span>Which NFT?</span>
              <input
                type="text"
                name="override_nft_used_text"
                value="<%= submission.nft_used_text || '' %>"
                maxlength="200"
                placeholder="Add the NFT used"
                data-nft-other-input
              />
            </label>
            <label class="field small-field">
              <span>Reward points</span>
              <input
                type="number"
                min="0"
                max="100000"
                name="reward_points"
                value="<%= submission.reward_points %>"
                required
                data-reward-input
              />
            </label>
            <button type="submit" class="button secondary">Save changes</button>
          </form>
        </div>
      </div>
    </article>
  <% }) %>
</section>

<script>
  (() => {
    const ERAS = <%- JSON.stringify(eras.map((era) => ({ key: era.key, allowedCollectionTypes: era.allowedCollectionTypes, defaultRewards: era.defaultRewards }))) %>;

    const getSuggestedReward = (nftUsedType, eraKey) => {
      return ERAS.find((era) => era.key === eraKey)?.defaultRewards?.[nftUsedType] ?? 0;
    };

    document.querySelectorAll("form.approve-form").forEach((form) => {
      const typeSelect = form.querySelector("[data-nft-type-select]");
      const eraSelect = form.querySelector('select[name="override_era_key"]');
      const otherField = form.querySelector("[data-nft-other-field]");
      const otherInput = form.querySelector("[data-nft-other-input]");
      const rewardInput = form.querySelector("[data-reward-input]");
      if (!typeSelect || !eraSelect || !otherField || !otherInput || !rewardInput) return;

      let lastSuggestedReward = String(getSuggestedReward(typeSelect.value, eraSelect.value));

      const syncForm = () => {
        const selectedEra = ERAS.find((era) => era.key === eraSelect.value);
        const allowsOther = selectedEra?.allowedCollectionTypes?.includes("other");
        const otherOption = typeSelect.querySelector('option[value="other"]');
        if (otherOption) otherOption.disabled = Boolean(selectedEra && !allowsOther);
        if (!allowsOther && typeSelect.value === "other") typeSelect.value = "squigs";
        const isOther = typeSelect.value === "other";
        otherField.classList.toggle("is-hidden", !isOther);
        otherInput.required = isOther;
        if (!isOther) otherInput.value = "";

        const suggestedReward = String(getSuggestedReward(typeSelect.value, eraSelect.value));
        if (!rewardInput.value || rewardInput.value === lastSuggestedReward) {
          rewardInput.value = suggestedReward;
        }
        lastSuggestedReward = suggestedReward;
      };

      typeSelect.addEventListener("change", syncForm);
      eraSelect.addEventListener("change", syncForm);
      syncForm();
    });
  })();
</script>

<%- include("partials/footer") %>
