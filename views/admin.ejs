<%- include("partials/header") %>

<%
  const repairEraLabelMap = (adminRepairEras || eras || []).reduce((map, era) => {
    map[era.key] = era.label;
    return map;
  }, {});
%>

<section class="stack-gap admin-page">
  <header class="dashboard-hero admin-hero">
    <div>
      <p class="eyebrow">Allowlisted Admin Console</p>
      <h1>Admin Review</h1>
      <p class="lead">
        Approve only images that clearly include at least 1 Squig, fit the selected milestone, are appropriate for the project, and are not gore, explicit content, hateful content, or unrelated spam.
      </p>
    </div>
    <div class="admin-stats" aria-label="Admin queue totals">
      <div><span>Pending</span><strong><%= submissions.length %></strong></div>
      <div><span>Approved</span><strong><%= approvedSubmissions.length %></strong></div>
    </div>
  </header>

  <section class="stack-gap review-section">
    <div class="section-title-row">
      <div>
        <p class="eyebrow">Pending Queue</p>
        <h2>Needs a human Squig check</h2>
      </div>
      <span class="submission-count"><%= submissions.length %></span>
    </div>

    <% if (!submissions.length) { %>
      <div class="panel empty-state">No pending submissions.</div>
    <% } %>

    <% submissions.forEach((submission) => { %>
      <article class="submission-card review-card">
        <div class="submission-media">
          <a href="<%= submission.image_url %>" target="_blank" rel="noreferrer">
            <img src="<%= submission.image_url %>" alt="Submission <%= submission.id %> preview" />
          </a>
          <span class="submission-status submission-status--pending">Awaiting Approval</span>
        </div>
        <div class="submission-body">
          <div class="submission-body__header">
            <div>
              <p class="eyebrow">Submission #<%= submission.id %></p>
              <h2><%= submission.milestone_label || submission.milestone_key || "Milestone not selected" %></h2>
            </div>
            <a href="<%= submission.image_url %>" target="_blank" rel="noreferrer" class="mini-link">Open image</a>
          </div>

          <dl class="meta-grid">
            <div><dt>Discord username</dt><dd><%= submission.discord_username %></dd></div>
            <div><dt>Discord user ID</dt><dd><%= submission.discord_user_id %></dd></div>
            <div><dt>Display name</dt><dd><%= submission.discord_display_name || "Not set" %></dd></div>
            <div><dt>Era</dt><dd>The Rise of Ugly City</dd></div>
            <div><dt>Selected milestone</dt><dd><%= submission.milestone_label || submission.milestone_key || "Not selected" %></dd></div>
            <div><dt>District</dt><dd><%= submission.milestone_district || "Not selected" %></dd></div>
            <div><dt>Squig confirmed by user</dt><dd><%= submission.contains_squig_confirmed ? "Yes" : "No" %></dd></div>
            <div><dt>Other collections included</dt><dd><%= submission.other_collections_text || submission.nft_used_text || "None provided" %></dd></div>
            <div><dt>Prompt used</dt><dd><%= submission.prompt_text || "Not provided" %></dd></div>
            <div><dt>Reward default</dt><dd><%= submission.reward_points || 100 %> $CHARM</dd></div>
            <div><dt>Submitted</dt><dd><%= new Date(submission.submitted_at).toLocaleString() %></dd></div>
            <div><dt>Image URL</dt><dd><a href="<%= submission.image_url %>" target="_blank" rel="noreferrer">Open image</a></dd></div>
          </dl>

          <div class="review-note">
            Decline if the image does not clearly contain a Squig.
          </div>

          <div class="actions review-actions">
            <form action="/admin/submissions/<%= submission.id %>/approve" method="post" class="approve-form review-form review-form--approve">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="row_version" value="<%= submission.row_version %>" />
              <div class="review-form__header">
                <p class="eyebrow">Approve</p>
                <strong>Send to live pool</strong>
              </div>
              <label class="field">
                <span>Override Discord user ID</span>
                <input
                  type="text"
                  name="override_discord_user_id"
                  inputmode="numeric"
                  placeholder="<%= submission.discord_user_id %>"
                />
              </label>
              <label class="field">
                <span>Override username</span>
                <input
                  type="text"
                  name="override_discord_username"
                  placeholder="<%= submission.discord_username %>"
                />
              </label>
              <label class="field">
                <span>Override display name</span>
                <input
                  type="text"
                  name="override_discord_display_name"
                  placeholder="<%= submission.discord_display_name || 'Not set' %>"
                />
              </label>
              <label class="field small-field">
                <span>Reward points</span>
                <input
                  type="number"
                  min="0"
                  max="100000"
                  name="reward_points"
                  value="<%= submission.reward_points || 100 %>"
                  required
                />
              </label>
              <button type="submit" class="button">Approve</button>
            </form>

            <form action="/admin/submissions/<%= submission.id %>/decline" method="post" class="review-form review-form--decline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="row_version" value="<%= submission.row_version %>" />
              <div class="review-form__header">
                <p class="eyebrow">Decline</p>
                <strong>Keep it out of the pool</strong>
              </div>
              <label class="field">
                <span>Decline reason</span>
                <textarea name="reason" rows="3" maxlength="500" required placeholder="No clear Squig, milestone mismatch, unsafe content, or spam"></textarea>
              </label>
              <button type="submit" class="button danger">Decline</button>
            </form>
          </div>
        </div>
      </article>
    <% }) %>
  </section>

  <section class="stack-gap review-section">
    <div class="section-title-row">
      <div>
        <p class="eyebrow">Approved Library</p>
        <h2>Live-pool images and repair tools</h2>
        <p class="muted">Approved entries remain visible here so admins can review and edit reward/account details later.</p>
      </div>
      <span class="submission-count"><%= approvedSubmissions.length %></span>
    </div>

    <% if (!approvedSubmissions.length) { %>
      <div class="panel empty-state">No approved images yet.</div>
    <% } %>

    <% approvedSubmissions.forEach((submission) => { %>
      <article class="submission-card review-card approved-card">
        <div class="submission-media">
          <a href="<%= submission.image_url %>" target="_blank" rel="noreferrer">
            <img src="<%= submission.image_url %>" alt="Approved submission <%= submission.id %> preview" />
          </a>
          <span class="submission-status submission-status--approved">Approved</span>
        </div>
        <div class="submission-body">
          <div class="submission-body__header">
            <div>
              <p class="eyebrow">Approved #<%= submission.id %></p>
              <h2><%= submission.milestone_label || submission.milestone_key || "Approved image" %></h2>
            </div>
            <a href="<%= submission.image_url %>" target="_blank" rel="noreferrer" class="mini-link">Open image</a>
          </div>

          <dl class="meta-grid">
            <div><dt>Discord username</dt><dd><%= submission.discord_username %></dd></div>
            <div><dt>Discord user ID</dt><dd><%= submission.discord_user_id %></dd></div>
            <div><dt>Display name</dt><dd><%= submission.discord_display_name || "Not set" %></dd></div>
            <div><dt>Era</dt><dd><%= repairEraLabelMap[submission.era_key] || submission.era_key || "Not set" %></dd></div>
            <div><dt>Milestone</dt><dd><%= submission.milestone_label || submission.milestone_key || "Not set" %></dd></div>
            <div><dt>Other collections</dt><dd><%= submission.other_collections_text || submission.nft_used_text || "None provided" %></dd></div>
            <div><dt>Prompt</dt><dd><%= submission.prompt_text || "Not provided" %></dd></div>
            <div><dt>Reward</dt><dd><%= submission.reward_points || 100 %> $CHARM</dd></div>
            <div><dt>Approved</dt><dd><%= submission.reviewed_at ? new Date(submission.reviewed_at).toLocaleString() : "Unknown" %></dd></div>
            <div><dt>Approved by</dt><dd><%= submission.reviewed_by || "Unknown" %></dd></div>
            <div><dt>Image URL</dt><dd><a href="<%= submission.image_url %>" target="_blank" rel="noreferrer">Open image</a></dd></div>
          </dl>

          <div class="actions review-actions">
            <form action="/admin/submissions/<%= submission.id %>/update-approved" method="post" class="approve-form review-form review-form--approve">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="row_version" value="<%= submission.row_version %>" />
              <div class="review-form__header">
                <p class="eyebrow">Edit approved row</p>
                <strong>Save account, reward, or era repair</strong>
              </div>
              <label class="field">
                <span>Discord user ID</span>
                <input
                  type="text"
                  name="override_discord_user_id"
                  inputmode="numeric"
                  value="<%= submission.discord_user_id %>"
                />
              </label>
              <label class="field">
                <span>Username</span>
                <input
                  type="text"
                  name="override_discord_username"
                  value="<%= submission.discord_username %>"
                />
              </label>
              <label class="field">
                <span>Display name</span>
                <input
                  type="text"
                  name="override_discord_display_name"
                  value="<%= submission.discord_display_name || '' %>"
                  placeholder="Not set"
                />
              </label>
              <label class="field">
                <span>Era key / game pool</span>
                <select name="override_era_key" required>
                  <% (adminRepairEras || eras).forEach((era) => { %>
                    <option value="<%= era.key %>" <%= era.key === submission.era_key ? "selected" : "" %>><%= era.label %></option>
                  <% }) %>
                </select>
                <small class="field-note">Admin repair only. New approvals still enter The Rise of Ugly City.</small>
              </label>
              <label class="field small-field">
                <span>Reward points</span>
                <input
                  type="number"
                  min="0"
                  max="100000"
                  name="reward_points"
                  value="<%= submission.reward_points || 100 %>"
                  required
                />
              </label>
              <button type="submit" class="button secondary">Save changes</button>
            </form>

            <form action="/admin/submissions/<%= submission.id %>/unapprove" method="post" class="review-form review-form--decline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="row_version" value="<%= submission.row_version %>" />
              <div class="review-form__header">
                <p class="eyebrow">Unapprove</p>
                <strong>Remove from live pool</strong>
              </div>
              <label class="field">
                <span>Unapprove reason</span>
                <textarea name="reason" rows="3" maxlength="500" required placeholder="Why should this image be removed from the live pool?"></textarea>
              </label>
              <button type="submit" class="button danger">Unapprove and remove from live pool</button>
            </form>
          </div>
        </div>
      </article>
    <% }) %>
  </section>
</section>

<%- include("partials/footer") %>
