<%- include("partials/header") %>

<%
  const eraLabel = eras[0]?.label || "The Rise of Ugly City";
  const recentCreations = submissions.slice(0, 8);
  const exampleCreations = Array.isArray(approvedExamples) ? approvedExamples : [];
  const spotlightCreations = recentCreations.length ? recentCreations : exampleCreations;
  const isExampleSpotlight = !recentCreations.length;
  const loopingSpotlightCreations = spotlightCreations.length > 1 ? spotlightCreations.concat(spotlightCreations) : spotlightCreations;
  const statusLabels = {
    pending: "Awaiting Approval",
    approved: "Approved",
    declined: "Declined",
  };
%>

<section class="stack-gap profile-page">
  <header class="profile-hero">
    <div class="profile-identity">
      <div class="profile-avatar" aria-hidden="true">
        <%= (user.displayName || user.username || "?").slice(0, 1).toUpperCase() %>
      </div>
      <div>
        <p class="eyebrow">Creator Profile</p>
        <h1><%= user.displayName || user.username %></h1>
        <p class="lead">Your Ugly Creator dashboard.</p>
      </div>
    </div>
  </header>

  <section class="profile-stats" aria-label="Submission totals">
    <article class="profile-stat profile-stat--total">
      <span>Total creations</span>
      <strong><%= stats.total %></strong>
      <p>Images submitted through the creator portal.</p>
    </article>
    <article class="profile-stat profile-stat--approved">
      <span>Approved</span>
      <strong><%= stats.approved %></strong>
      <p>Eligible for the Ugly City image pool.</p>
    </article>
    <article class="profile-stat profile-stat--pending">
      <span>Pending</span>
      <strong><%= stats.pending %></strong>
      <p>Waiting for admin review.</p>
    </article>
    <article class="profile-stat profile-stat--declined">
      <span>Declined</span>
      <strong><%= stats.declined %></strong>
      <p>Reviewed but not accepted.</p>
    </article>
  </section>

  <section class="profile-feature-grid">
    <article class="profile-feature-card profile-feature-card--latest profile-feature-card--wide">
      <div class="profile-latest-header">
        <div>
          <p class="eyebrow"><%= isExampleSpotlight ? "Approved Creator Examples" : "Recent Creations" %></p>
          <h2><%= isExampleSpotlight ? "See what creators are building" : "Your latest creations" %></h2>
        </div>
        <% if (spotlightCreations.length) { %>
          <span><%= isExampleSpotlight ? "Main page examples" : `${spotlightCreations.length} recent ${spotlightCreations.length === 1 ? "image" : "images"}` %></span>
        <% } %>
      </div>

      <% if (spotlightCreations.length) { %>
        <div class="profile-creation-window">
          <div class="profile-creation-track <%= spotlightCreations.length === 1 ? 'profile-creation-track--single' : '' %>">
            <% loopingSpotlightCreations.forEach((creation) => { %>
              <figure class="profile-creation-card">
                <a href="<%= creation.image_url %>" target="_blank" rel="noreferrer" class="profile-latest-media">
                  <img src="<%= creation.image_url %>" alt="<%= isExampleSpotlight ? 'Approved creator example' : 'Submitted image ' + creation.id %>" loading="lazy" />
                </a>
                <figcaption class="profile-latest-meta">
                  <% if (isExampleSpotlight) { %>
                    <span class="submission-status submission-status--approved">Approved example</span>
                  <% } else { %>
                    <span class="submission-status submission-status--<%= creation.status %>"><%= statusLabels[creation.status] || creation.status %></span>
                  <% } %>
                  <strong><%= creation.milestone_label || creation.milestone_key || creation.milestone_district || eraLabel %></strong>
                  <% if (!isExampleSpotlight && creation.submitted_at) { %>
                    <small><%= new Date(creation.submitted_at).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %></small>
                  <% } else { %>
                    <small><%= creation.milestone_district || eraLabel %></small>
                  <% } %>
                </figcaption>
              </figure>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="profile-empty-art">
          <span>NO IMAGES YET</span>
        </div>
        <p>No recent creations or approved examples are available yet.</p>
      <% } %>
    </article>

    <div class="profile-feature-actions">
      <a class="button" href="/submit">Submit New Image</a>
    </div>
  </section>

  <section class="stack-gap profile-gallery">
    <div class="submission-history__header">
      <p class="eyebrow">Creation Archive</p>
      <h2>Everything you have submitted</h2>
      <p class="muted">Approved images become eligible for the Ugly City image pool. Pending images are still waiting for admin review.</p>
    </div>

    <% if (!submissions.length) { %>
      <div class="panel empty-state">
        No creations yet. The city remains dangerously underbuilt.
      </div>
    <% } else { %>
      <div class="submission-grid profile-submission-grid">
        <% submissions.forEach((submission) => { %>
          <article class="submission-tile submission-tile--<%= submission.status %>">
            <a href="<%= submission.image_url %>" target="_blank" rel="noreferrer" class="submission-tile__media">
              <img src="<%= submission.image_url %>" alt="Submitted image <%= submission.id %>" loading="lazy" />
            </a>
            <div class="submission-tile__body">
              <div class="submission-tile__topline">
                <span class="submission-status submission-status--<%= submission.status %>">
                  <%= statusLabels[submission.status] || submission.status %>
                </span>
                <span class="submission-tile__date">
                  <%= new Date(submission.submitted_at).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %>
                </span>
              </div>

              <dl class="submission-tile__meta">
                <div>
                  <dt>Era</dt>
                  <dd><%= eraLabel %></dd>
                </div>
                <div>
                  <dt>Milestone</dt>
                  <dd><%= submission.milestone_label || submission.milestone_key || "Not set" %></dd>
                </div>
                <div>
                  <dt>Reward</dt>
                  <dd><%= submission.reward_points || 100 %> $CHARM</dd>
                </div>
                <% if (submission.status !== "pending") { %>
                  <div>
                    <dt>Reviewed</dt>
                    <dd>
                      <%= submission.reviewed_at ? new Date(submission.reviewed_at).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) : "Not available" %>
                    </dd>
                  </div>
                <% } %>
                <% if (submission.status === "declined" && submission.decline_reason) { %>
                  <div class="decline-reason">
                    <dt>Reason</dt>
                    <dd><%= submission.decline_reason %></dd>
                  </div>
                <% } %>
              </dl>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</section>

<%- include("partials/footer") %>
