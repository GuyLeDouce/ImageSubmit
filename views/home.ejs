<%- include("partials/header") %>

<%
  const examples = Array.isArray(approvedExamples) ? approvedExamples : [];
%>

<section class="landing-hero">
  <div class="landing-hero__copy">
    <p class="eyebrow">Ugly Labs Submission Gate</p>
    <h1>Help build Ugly City</h1>
    <p class="creator-hero__tagline">
      Use your Squigs and create images for the different milestones for the Rise of Ugly City, the new era for Squig Survival.
    </p>
    <p class="lead">Admin-approved submissions earn 100 $CHARM and may enter the game image pool. No Squig, no approval.</p>

    <div class="landing-actions">
      <% if (!user) { %>
        <a class="button" href="/auth/discord">Login with Discord</a>
      <% } else if (user.isGuildMember) { %>
        <a class="button" href="/submit">Start Submission</a>
      <% } else { %>
        <a class="button" href="<%= links.discord %>" target="_blank" rel="noreferrer">Join Ugly Labs Discord</a>
      <% } %>
      <a class="text-cta" href="#rules">Read the rules</a>
    </div>
  </div>

  <aside class="landing-hero__visual" aria-label="Approved creator examples">
    <div class="approved-example-showcase">
      <div class="approved-example-header">
        <p class="eyebrow">Approved Creator Examples</p>
        <span>Rotating from the live approval pool</span>
      </div>
      <% if (examples.length) { %>
        <div class="approved-example-window">
          <div class="approved-example-track">
            <% examples.concat(examples).forEach((example, index) => { %>
              <figure class="approved-example-card">
                <img src="<%= example.image_url %>" alt="Approved Squig creator image for <%= example.milestone_label || example.milestone_district || 'The Rise of Ugly City' %>" loading="lazy" />
                <figcaption>
                  <span>Approved example</span>
                  <strong><%= example.milestone_label || example.milestone_district || "Ugly City image pool" %></strong>
                </figcaption>
              </figure>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="approved-example-empty">
          <span>Approved examples will appear here</span>
          <p>Your approved image could become one of the examples creators see first.</p>
        </div>
      <% } %>
    </div>
  </aside>
</section>

<section class="creator-section simple-section" id="how-it-works">
  <div class="creator-section__heading">
    <p class="eyebrow">How It Works</p>
    <h2>Keep it simple, keep it UGLY.</h2>
  </div>
  <div class="simple-steps">
    <article class="simple-step">
      <span>01</span>
      <h3>Pick a milestone in the submit form</h3>
      <p>You choose the Ugly City chapter your image was made for after you log in.</p>
    </article>
    <article class="simple-step">
      <span>02</span>
      <h3>Upload an image with at least one Squig</h3>
      <p>Use any tools at your disposal to create images with your Squigs.</p>
    </article>
    <article class="simple-step">
      <span>03</span>
      <h3>Admins review it</h3>
      <p>Your approved image will randomly appear in the Squig Survival game during the milestone you selected, earning you 100 $CHARM each time.</p>
    </article>
  </div>
</section>

<section class="creator-section rules-panel" id="rules">
  <div class="creator-section__heading">
    <p class="eyebrow">Rules</p>
    <h2>Simple guidelines to ensure Ugly approval.</h2>
  </div>
  <ul class="rules-list-simple">
    <li>Must include at least one clearly visible Squig.</li>
    <li>Other NFTs or images are allowed if a Squig is present.</li>
    <li>Ensure you choose the Ugly City milestone that best suits your image creation.</li>
    <li>Admin approval is required.</li>
    <li>Approval does not guarantee final in-game use, image use is randomized within the game.</li>
  </ul>
</section>

<section class="final-cta">
  <div>
    <p class="eyebrow">Ready to Create</p>
    <h2>Your Squig belongs somewhere in Ugly City.</h2>
  </div>
  <div class="actions">
    <% if (!user) { %>
      <a class="button" href="/auth/discord">Login with Discord</a>
    <% } else if (user.isGuildMember) { %>
      <a class="button" href="/submit">Start Submission</a>
    <% } else { %>
      <a class="button" href="<%= links.discord %>" target="_blank" rel="noreferrer">Join Ugly Labs Discord</a>
    <% } %>
  </div>
</section>

<%- include("partials/footer") %>
