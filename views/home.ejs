<%- include("partials/header") %>

<section class="ugly-hero">
  <div class="ugly-hero__copy">
    <p class="eyebrow">Squig Survival Presents</p>
    <h1>The Ugly City Image Factory</h1>
    <p class="creator-hero__tagline">
      Squig Survival is building the world's worst city, one milestone at a time. Every chapter unlocks a new district, and the community gets to help decide what Ugly City looks like.
    </p>
    <p class="lead">
      Submit your Squigs into the districts. Build the chaos. Feed the game. Earn 100 $CHARM when your image is approved.
    </p>
    <div class="actions">
      <% if (!user) { %>
        <a class="button" href="/auth/discord">Login with Discord to Submit</a>
      <% } else if (user.isGuildMember) { %>
        <a class="button" href="#milestones">Start Building Ugly City</a>
      <% } else { %>
        <a class="button" href="<%= links.discord %>" target="_blank" rel="noreferrer">Join Ugly Labs Discord</a>
      <% } %>
      <a class="button secondary" href="#rules">Submission Rules</a>
    </div>
  </div>

  <aside class="ugly-hero__board">
    <p class="eyebrow">Reward</p>
    <p class="ugly-reward">100 <span>$CHARM</span></p>
    <p class="muted">Every approved image becomes eligible for the Ugly City image pool. Admin approval does not guarantee in-game appearance.</p>
  </aside>
</section>

<section class="creator-section" id="how-it-works">
  <div class="creator-section__heading">
    <p class="eyebrow">How It Works</p>
    <h2>Pick a chapter, upload the chaos, wait for review.</h2>
  </div>
  <ol class="creator-steps">
    <li>Pick the Ugly City milestone your image fits.</li>
    <li>Attach an image that includes at least one Squig.</li>
    <li>Add optional prompt or other collection notes.</li>
    <li>Admins review it for Squig presence, milestone fit, safety, and project fit.</li>
    <li>Approved images earn 100 $CHARM and enter the Ugly City image pool.</li>
  </ol>
</section>

<section class="creator-section" id="rules">
  <div class="creator-section__heading">
    <p class="eyebrow">Submission Rules</p>
    <h2>No Squig, no approval.</h2>
  </div>
  <ul class="creator-tags rules-list">
    <li>Must include at least 1 Squig</li>
    <li>Other NFTs or images are allowed, but a Squig must be clearly present</li>
    <li>Pick the milestone your image was made for</li>
    <li>Admins review every submission</li>
    <li>Approved images earn 100 $CHARM</li>
    <li>Approved images enter the Ugly City image pool</li>
  </ul>
</section>

<section class="creator-section rewards-strip">
  <div class="creator-section__heading">
    <p class="eyebrow">Rewards</p>
    <h2>100 $CHARM per approved Ugly City image.</h2>
    <p class="muted">Images become eligible for The Rise of Ugly City after approval. Final game usage is curated by the project team.</p>
  </div>
</section>

<section class="creator-section" id="milestones">
  <div class="creator-section__heading">
    <p class="eyebrow">Choose Your Milestone</p>
    <h2>Build the city map one bad decision at a time.</h2>
    <p class="muted">Each milestone opens the submit form with that chapter selected.</p>
  </div>

  <div class="milestone-grid">
    <% milestones.forEach((milestone) => { %>
      <a class="milestone-card" href="/submit?milestone=<%= encodeURIComponent(milestone.key) %>">
        <span class="milestone-card__number"><%= milestone.number %></span>
        <span class="milestone-card__name"><%= milestone.district %></span>
      </a>
    <% }) %>
  </div>
</section>

<section class="creator-cta">
  <div class="creator-section__heading">
    <p class="eyebrow">Factory Floor</p>
    <h2>Ugly City is not going to build itself. Unfortunately, the Squigs are helping.</h2>
  </div>
  <div class="actions">
    <% if (!user) { %>
      <a class="button" href="/auth/discord">Login with Discord to Submit</a>
    <% } else if (user.isGuildMember) { %>
      <a class="button" href="#milestones">Pick a Milestone and Submit</a>
    <% } else { %>
      <a class="button" href="<%= links.discord %>" target="_blank" rel="noreferrer">Join Ugly Labs Discord</a>
    <% } %>
    <a class="button secondary" href="<%= links.discord %>" target="_blank" rel="noreferrer">Discord</a>
  </div>
</section>

<%- include("partials/footer") %>
