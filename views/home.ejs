<%- include("partials/header") %>

<section class="landing-hero">
  <div class="landing-hero__copy">
    <p class="eyebrow">Ugly Labs Submission Gate</p>
    <h1>Submit Squig moments for Ugly City</h1>
    <p class="creator-hero__tagline">
      Upload community-made Squig images for The Rise of Ugly City. Admin-approved submissions earn 100 $CHARM and may enter the game image pool.
    </p>
    <p class="lead">No Squig, no approval. Keep at least one Squig clearly visible.</p>

    <div class="landing-actions">
      <% if (!user) { %>
        <a class="button" href="/auth/discord">Login with Discord</a>
      <% } else if (user.isGuildMember) { %>
        <a class="button" href="/submit">Start Submission</a>
      <% } else { %>
        <a class="button" href="<%= links.discord %>" target="_blank" rel="noreferrer">Join Ugly Labs Discord</a>
      <% } %>
      <a class="text-cta" href="#rules">Read the rules</a>
    </div>

    <div class="info-chips" aria-label="Submission basics">
      <span class="info-chip">Discord required</span>
      <span class="info-chip">Squigs only</span>
      <span class="info-chip">Admin reviewed</span>
      <span class="info-chip">100 $CHARM</span>
    </div>
  </div>

  <aside class="landing-hero__visual" aria-label="Example Squig creation previews">
    <div class="example-stack">
      <figure class="example-card example-card--primary">
        <img src="/characters/Untitled%20design%20(1).png" alt="Example Squig character moment for Ugly City" loading="lazy" />
        <figcaption>Example Squig moment</figcaption>
      </figure>
      <figure class="example-card example-card--secondary">
        <img src="/characters/Untitled%20design%20(2).png" alt="Example Squig image matched to an Ugly City milestone" loading="lazy" />
        <figcaption>Milestone fit</figcaption>
      </figure>
      <figure class="example-card example-card--tertiary">
        <img src="/characters/Untitled%20design%20(3).png" alt="Example Squig image ready for admin review" loading="lazy" />
        <figcaption>Ready for review</figcaption>
      </figure>
    </div>
  </aside>
</section>

<section class="creator-section simple-section" id="how-it-works">
  <div class="creator-section__heading">
    <p class="eyebrow">How It Works</p>
    <h2>Three steps. Keep it Squiggy.</h2>
  </div>
  <div class="simple-steps">
    <article class="simple-step">
      <span>01</span>
      <h3>Pick a milestone in the submit form</h3>
      <p>Choose the Ugly City chapter your image was made for after you log in.</p>
    </article>
    <article class="simple-step">
      <span>02</span>
      <h3>Upload an image with at least one Squig</h3>
      <p>Other NFTs, memes, and backgrounds are fine if a Squig is clearly visible.</p>
    </article>
    <article class="simple-step">
      <span>03</span>
      <h3>Admins review it</h3>
      <p>Approved images earn 100 $CHARM and may enter the Ugly City image pool.</p>
    </article>
  </div>
</section>

<section class="creator-section rules-panel" id="rules">
  <div class="creator-section__heading">
    <p class="eyebrow">Rules</p>
    <h2>Simple rules for a weird city.</h2>
  </div>
  <ul class="rules-list-simple">
    <li>Must include at least one clearly visible Squig.</li>
    <li>Other NFTs or images are allowed if a Squig is present.</li>
    <li>Pick the closest Ugly City milestone on the submit page.</li>
    <li>Admin approval is required.</li>
    <li>Approval does not guarantee final in-game use.</li>
  </ul>
</section>

<section class="final-cta">
  <div>
    <p class="eyebrow">Ready for Review?</p>
    <h2>Submit something ugly enough for the city.</h2>
  </div>
  <div class="actions">
    <% if (!user) { %>
      <a class="button" href="/auth/discord">Login with Discord</a>
    <% } else if (user.isGuildMember) { %>
      <a class="button" href="/submit">Start Submission</a>
    <% } else { %>
      <a class="button" href="<%= links.discord %>" target="_blank" rel="noreferrer">Join Ugly Labs Discord</a>
    <% } %>
  </div>
</section>

<%- include("partials/footer") %>
